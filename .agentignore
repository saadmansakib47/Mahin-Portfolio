# Ignore large binary/generated directories
node_modules/
.next/
out/
dist/
build/

# Ignore environment files with secrets
.env
.env.local
.env.*.local

# Ignore OS metadata
.DS_Store
Thumbs.db

# Ignore editor config
.vscode/
.idea/

# Ignore lock files (large, auto-generated)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Ignore TypeScript incremental build info
*.tsbuildinfo

# Ignore log files
*.log
npm-debug.log*
